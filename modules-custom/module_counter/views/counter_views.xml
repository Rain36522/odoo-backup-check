<odoo>
    <record id="view_counter_form" model="ir.ui.view">
        <field name="name">button.counter.form</field>
        <field name="model">button.counter</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_increment"
                            type="object"
                            string="Cliquer"
                            class="btn-primary"
                            invisible="state == 'done'"/>

                    <button name="action_done"
                            type="object"
                            string="Terminer"
                            class="btn-secondary"
                            invisible="state == 'done'"/>
                </header>

                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="counter" readonly="1"/>
                        <field name="state" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_counter" model="ir.actions.act_window">
        <field name="name">Compteur</field>
        <field name="res_model">button.counter</field>
        <field name="view_mode">form</field>
    </record>

    <menuitem id="menu_counter_root" name="Counter"/>
    <menuitem id="menu_counter"
              name="Compteur"
              parent="menu_counter_root"
              action="action_counter"/>
</odoo>